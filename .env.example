# =============================================================================
# Metabase MCP Server - Environment Configuration
# =============================================================================

# Required: Your Metabase instance URL
METABASE_URL=https://your-metabase-instance.example.com

# Required: Metabase API key
# Generate one in Metabase Admin > Settings > API Keys
METABASE_API_KEY=mb_your_api_key_here

# Server mode: read | write | full (default: read)
MCP_MODE=read

# Performance tuning
METABASE_TIMEOUT=30000
METABASE_MAX_ROWS=10000

# Logging
LOG_LEVEL=info
# AUDIT_LOG_FILE=./audit.log

# Rate limiting (per-tier, requests per minute)
# RATE_LIMIT_READ_PER_MINUTE=120
# RATE_LIMIT_WRITE_PER_MINUTE=30
# RATE_LIMIT_LLM_PER_MINUTE=20
# Legacy: applies to the read tier when RATE_LIMIT_READ_PER_MINUTE is unset
# RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Per-tool access control (comma-separated tool names; deny wins over allow)
# Also enforced inside batch_execute and run_workflow operations
# MCP_TOOLS_ALLOW=list_dashboards,get_dashboard,execute_card
# MCP_TOOLS_DENY=execute_query,delete_card,delete_dashboard

# =============================================================================
# NLQ Features (optional - requires Anthropic API key)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_DAILY_TOKEN_LIMIT=100000
# LLM_MONTHLY_TOKEN_LIMIT=2000000
