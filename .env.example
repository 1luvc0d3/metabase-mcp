# =============================================================================
# Metabase MCP Server - Environment Configuration
# =============================================================================

# Required: Your Metabase instance URL
METABASE_URL=https://your-metabase-instance.example.com

# Required: Metabase API key
# Generate one in Metabase Admin > Settings > API Keys
METABASE_API_KEY=mb_your_api_key_here

# Server mode: read | write | full (default: read)
MCP_MODE=read

# Performance tuning
METABASE_TIMEOUT=30000
METABASE_MAX_ROWS=10000

# Logging
LOG_LEVEL=info
# AUDIT_LOG_FILE=./audit.log

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# =============================================================================
# NLQ Features (optional - requires Anthropic API key)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_DAILY_TOKEN_LIMIT=100000
# LLM_MONTHLY_TOKEN_LIMIT=2000000
