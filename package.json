{
  "name": "@ai-1luvc0d3/metabase-mcp",
  "version": "1.0.2",
  "description": "MCP server connecting Claude to Metabase for data analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "metabase-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/1luvc0d3/metabase-mcp.git"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "validate-config": "node dist/validate-config.js"
  },
  "keywords": [
    "metabase",
    "mcp",
    "claude",
    "anthropic",
    "model-context-protocol",
    "sql",
    "data-analysis"
  ],
  "author": "PyMlandBeyond",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
